generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Movie {
  id          String   @id @default(uuid())
  archiveId   String   @unique  // e.g. "night_of_the_living_dead"
  title       String
  description String?  @db.Text
  year        Int?
  
  // Normalized runtime in minutes (e.g. 96)
  runtime     Int?     
  
  // The exact path to the highest quality MP4 (e.g. "/movies/night.mp4")
  videoFile   String?  
  
  // The path to the thumbnail
  posterFile  String?  

  downloads   Int      @default(0)
  rating      Float?

  creator     String?  // Director / Artist
  language    String?  // e.g. "English", "French"
  color       String?  // "color" or "black and white"
  licenseUrl  String?  // Public Domain badge

  publicDate  DateTime? // Maps to Archive's "publicdate"

  isVerified  Boolean  @default(false) // Whether the movie has been verified for quality and metadata accuracy

  // Relationships (Many-to-Many)
  categories  Category[]
  tags        Tag[]
  reviews     Review[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Review {
  id        String   @id @default(uuid())
  author    String
  body      String   @db.Text
  rating    Int?     // 1-5 stars
  date      DateTime?
  
  movieId   String
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
}

model Category {
  id     String  @id @default(uuid())
  name   String  @unique // e.g. "SciFi_Horror", "Comedy_Films"
  movies Movie[]
}

model Tag {
  id     String  @id @default(uuid())
  name   String  @unique // e.g. "black_and_white", "zombie"
  movies Movie[]
}